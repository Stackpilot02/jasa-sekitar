// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CONSUMER
  PROVIDER
  ADMIN
}

enum BookingStatus {
  WAITING
  CONFIRMED
  EN_ROUTE
  IN_PROGRESS
  FINISHED
  CANCELLED
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  phone         String?   @unique
  password      String
  name          String
  role          UserRole  @default(CONSUMER)
  avatarUrl     String?
  isVerified    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Consumer relationships
  bookings      Booking[] @relation("ConsumerBookings")
  reviews       Review[]

  // Provider relationships
  providerProfile ProviderProfile?
  assignedBookings Booking[] @relation("ProviderBookings")
}

model ProviderProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  bio             String?
  category        String
  specialization  String[]
  experience      Int?     // years
  rating          Float    @default(0)
  reviewCount     Int      @default(0)
  basePrice       Float
  location        String?
  latitude        Float?
  longitude       Float?
  portfolio       String[] // array of image URLs
  ktpVerified     Boolean  @default(false)
  isPremium       Boolean  @default(false)
}

model Booking {
  id              String        @id @default(uuid())
  consumerId      String
  consumer        User          @relation("ConsumerBookings", fields: [consumerId], references: [id])
  providerId      String
  provider        User          @relation("ProviderBookings", fields: [providerId], references: [id])
  serviceType     String
  status          BookingStatus @default(WAITING)
  scheduledAt     DateTime
  location        String
  latitude        Float
  longitude       Float
  totalPrice      Float
  paymentStatus   String        @default("PENDING")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  review          Review?
}

model Review {
  id          String   @id @default(uuid())
  bookingId   String   @unique
  booking     Booking  @relation(fields: [bookingId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  rating      Int
  comment     String?
  tip         Float    @default(0)
  createdAt   DateTime @default(now())
}
